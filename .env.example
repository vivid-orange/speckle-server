# Speckle Server Docker Compose Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Your server's public domain (without protocol)
DOMAIN=speckle.example.com

# =============================================================================
# SESSION & SECURITY
# =============================================================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=speckle
POSTGRES_PASSWORD=speckle
POSTGRES_DB=speckle

# =============================================================================
# OBJECT STORAGE (S3/MinIO)
# =============================================================================
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=speckle-server

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Set to 'true' to enable email functionality
EMAIL_ENABLED=false

# SMTP server settings
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_FROM=no-reply@example.com

# SMTP authentication
EMAIL_USERNAME=
EMAIL_PASSWORD=

# TLS settings
# EMAIL_SECURE: Use implicit TLS (port 465)
# EMAIL_REQUIRE_TLS: Use STARTTLS (port 587)
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true

# -----------------------------------------------------------------------------
# Azure Communication Services Example:
# EMAIL_HOST=smtp.azurecomm.net
# EMAIL_PORT=587
# EMAIL_FROM=DoNotReply@your-domain.azurecomm.net
# EMAIL_USERNAME=your-acs-resource-name|your-entra-app-id|your-tenant-id
# EMAIL_PASSWORD=your-entra-app-client-secret
# EMAIL_SECURE=false
# EMAIL_REQUIRE_TLS=true
# -----------------------------------------------------------------------------
